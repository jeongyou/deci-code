{
  "permissions": {
    "allow": ["Bash(*)"],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo rm *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(git tag -d *)",
      "Bash(pnpm publish*)",
      "Bash(npm publish*)",
      "Bash(kill -9 *)",
      "Bash(pkill *)",
      "Bash(crontab -r*)",
      "Bash(chmod 777 *)",
      "Bash(dd *)",
      "Bash(mkfs *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "./check.sh",
            "timeout": 120,
            "statusMessage": "커밋 전 check.sh 실행 중..."
          }
        ]
      }
    ]
  }
}
